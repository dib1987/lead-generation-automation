# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=leadgen
DATABASE_URL=postgresql+asyncpg://leadgen:changeme@postgres:5432/leadgen

# ─────────────────────────────────────────────
# Redis / Celery
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# AWS SES — email delivery
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
# Must be a verified sender identity in SES
SES_VERIFIED_SENDER=your-verified-sender@example.com

# ─────────────────────────────────────────────
# Anthropic — LLM email generation
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key

# ─────────────────────────────────────────────
# HubSpot CRM
# ─────────────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-api-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-secret-key
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# ─────────────────────────────────────────────
# Admin dashboard (Phase 2)
# ─────────────────────────────────────────────
# API key that guards /api/v1/admin/* — leave empty to disable auth (dev only)
ADMIN_API_KEY=change-this-to-a-random-admin-key

# ─────────────────────────────────────────────
# Unsubscribe links (Phase 5A)
# ─────────────────────────────────────────────
# Full base URL used to build unsubscribe links in outgoing emails.
# In dev the default (http://localhost:8000) is used automatically.
# Set this to your public domain in production.
APP_BASE_URL=https://yourdomain.com

# ─────────────────────────────────────────────
# Alerting & Webhooks (Phase 1C)
# ─────────────────────────────────────────────
# Optional — leave empty to disable failure alert emails
ADMIN_ALERT_EMAIL=
# Optional — leave empty to disable SES webhook auth
WEBHOOK_SECRET=
